	(text_box "28-pin inverter connector\n1 - Start\n2 - Motortemp 1\n3 - Throttle 1\n4 - Throttle 2\n5 - Cruise\n6 - Brake\n7 - +12v (kl30)\n8 - Motortemp 2\n9\n10\n11\n12\n13 - +15 Ignition (kl15)\n14 - +5v Out\n15 - CAN-L\n16 - Motortemp 1\n17 - Resolver SIN S4\n18 - Resolver SIN S2\n19 - Resolver EXC R2\n20\n21\n22 - CAN-H\n23 - Motortemp 2\n24 - Resolver COS S3\n25 - Resolver COS S1\n26 - Resolver EXC R1\n27 - Reverse\n28 - Forward"
		(exclude_from_sim no)
		(at 758.19 31.75 0)
		(size 62.23 119.38)
